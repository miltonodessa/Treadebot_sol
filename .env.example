# ── Обязательные настройки ────────────────────────────────────────────────────

# Helius API key (бесплатно на https://helius.dev)
HELIUS_API_KEY=your_helius_api_key_here

# Твой торговый кошелёк (приватный ключ в base58)
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# ── Торговые параметры ────────────────────────────────────────────────────────
# 2TE2F торгует на 2-5 SOL. При COPY_SCALE_FACTOR=0.1 мы будем на 0.2-0.5 SOL
COPY_SCALE_FACTOR=0.1

# Максимум SOL в одной сделке
MAX_SOL_PER_TRADE=0.5

# Минимум SOL (пропускаем пыль)
MIN_SOL_PER_TRADE=0.05

# Максимум % от баланса на позицию
MAX_PORTFOLIO_PCT=0.10

# Максимум одновременных позиций
MAX_OPEN_POSITIONS=5

# Slippage (basis points, 100 = 1%)
SLIPPAGE_BPS=100

# Priority fee microlamports (выше = быстрее исполнение)
PRIORITY_FEE_MICROLAMPORTS=500000

# ── Риск-менеджмент ───────────────────────────────────────────────────────────
# Дневной лимит убытка (бот остановится)
DAILY_LOSS_LIMIT_SOL=1.0

# Стоп-лосс на позицию (0.25 = 25%)
STOP_LOSS_PCT=0.25

# Emergency exit если не продали за N секунд
MAX_HOLD_SECS=300

# Порог прибыли для конвертации в USDC
PROFIT_PARK_SOL=5.0

# ── Фильтры ───────────────────────────────────────────────────────────────────
# Blacklist через запятую (mint адреса)
TOKEN_BLACKLIST=
