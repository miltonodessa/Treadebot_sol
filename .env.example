# ══════════════════════════════════════════════════════════════════════════════
#  PUMPSCALP v4.0 — Pump.fun Direct Bonding Curve Sniper
#  Стратегия основана на анализе 101,190 сделок кошелька nya666...
#  Данные: WR=34.6%, EV=+2.7%/сделку, ~1,700 сделок/день
#
#  Копируй этот файл: cp .env.example .env
#  Заполни OUR_PRIVATE_KEY и HELIUS_API_KEY — остальное опционально.
# ══════════════════════════════════════════════════════════════════════════════

# ── API ────────────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here

# ── Кошелёк ────────────────────────────────────────────────────────────────────
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# ── Режим ──────────────────────────────────────────────────────────────────────
DRY_RUN=true                # true = симуляция без реальных транзакций
VIRTUAL_BALANCE_SOL=50.0   # виртуальный баланс для DRY RUN

# ── Размер позиций ─────────────────────────────────────────────────────────────
# Медиана из данных nya666: 0.338 SOL на вход
BUY_SIZE_SOL=0.3
BUY_SIZE_REENTRY_SOL=0.3
MAX_POSITIONS=10

# ── Checkpoint 1: QUICK_STOP (T+8s) ───────────────────────────────────────────
# 6,520 выходов на 5-10s — крупнейший кластер потерь.
# Цена не выросла → токен мёртвый → выходим.
QUICK_STOP_SEC=8

# ── Checkpoint 2: MOMENTUM_GATE (T+25s) ───────────────────────────────────────
# Рост < 5% к T+25s → нет momentum → выходим.
# + dead zone: 3-50 покупателей в первые 30s → WR=1-20% → выходим.
MOMENTUM_GATE_SEC=25
MOMENTUM_MIN_PCT=0.05

# ── Фильтры входа (из анализа 25,987 сделок) ──────────────────────────────────
DEV_BUY_SKIP_MIN_SOL=0.5   # dev buy >= 0.5 SOL → WR=16.3% → пропуск
BUYER_DEAD_ZONE_MIN=3       # dead zone: 3-50 покупателей в 30s → WR=1-20%
BUYER_DEAD_ZONE_MAX=50

# ── Take-Profit уровни ─────────────────────────────────────────────────────────
TP1_PCT=0.50                # +50% → продать 35%
TP1_SELL_FRAC=0.35
TP2_PCT=1.00                # +100% → продать 50% остатка
TP2_SELL_FRAC=0.50
TP3_PCT=5.00                # +500% → продать всё
TP3_SELL_FRAC=1.00

# ── Trailing Stop ──────────────────────────────────────────────────────────────
TRAILING_TRIGGER_PCT=0.50   # активируется после +50%
TRAILING_DISTANCE=0.15      # тянется в -15% от пика

# ── Stop-Loss ──────────────────────────────────────────────────────────────────
SL_PCT=0.15                 # avg loss из данных = -17.8% → SL на -15%

# ── Time Stop ──────────────────────────────────────────────────────────────────
HARD_TIME_STOP_MIN=8        # WR >5 мин = 55%, держим долго

# ── Re-entry ───────────────────────────────────────────────────────────────────
REENTRY_MIN_SEC=60
REENTRY_MAX_SEC=300
REENTRY_MIN_PUMP_PCT=0.02
MAX_REENTRIES=2

# ── Token Age ──────────────────────────────────────────────────────────────────
MAX_TOKEN_AGE_SEC=120       # только токены младше 2 мин

# ── Риск ───────────────────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_SOL=5.0

# ── Исполнение ─────────────────────────────────────────────────────────────────
PRIORITY_FEE_MICROLAMPORTS=500000
SLIPPAGE_BPS=1000

# ── ML самообучение (обновляется автоматически через train_daily.sh) ────────────
# ML_PARAMS_FILE=ml_params.json
# MASTER_LOG=trade_log_master.csv
# TRAIN_WINDOW_DAYS=30
# OPTUNA_TRIALS=300

# ── copy-trading strategy_bot.py (если используешь) ────────────────────────────
# COPY_SCALE_FACTOR=0.1
# MAX_SOL_PER_TRADE=0.5
