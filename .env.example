# ══════════════════════════════════════════════════════════════════
#  PUMPSCALP v1.0 — конфигурация
#  Скопируй в .env и заполни свои значения
# ══════════════════════════════════════════════════════════════════

# ── Режим работы ──────────────────────────────────────────────────
# true  = dry run (виртуальные деньги, реальных сделок НЕТ) ← старт отсюда
# false = боевой режим (реальные деньги)
DRY_RUN=true

# Стартовый баланс для dry run (SOL)
VIRTUAL_BALANCE_SOL=50.0

# ── Обязательные API ключи ────────────────────────────────────────
# Helius RPC (free tier): https://helius.xyz
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye (free tier): https://birdeye.so/developer
# Используется для volume, buy_pressure, unique_wallets — нужен для точного скоринга
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Кошелёк (только для боевого режима DRY_RUN=false) ────────────
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# ── Сигнальная система ────────────────────────────────────────────
# Минимальный Score для входа (макс 195)
# 70 = стандартный порог по стратегии
SCORE_THRESHOLD=70

# Максимальный возраст токена для входа (минуты)
MAX_TOKEN_AGE_MIN=30

# Сканировать watchlist каждые N секунд
SCAN_INTERVAL_SEC=30

# ── Размер позиции ────────────────────────────────────────────────
# Доля банка на одну сделку (Kelly 1/4 ÷ 5 позиций = 2.3%)
POSITION_SIZE_PCT=0.023

# Максимум одновременных позиций
MAX_POSITIONS=5

# ── Уровни выхода ─────────────────────────────────────────────────
# TP1: +15% → продать 50% позиции
TP1_PCT=0.15
TP1_FRACTION=0.50

# TP2: +30% → продать 35% позиции
TP2_PCT=0.30
TP2_FRACTION=0.35

# TP3: +100% → продать остаток (15%)
TP3_PCT=1.00

# Стоп-лосс: -8% от входа
SL_PCT=0.08

# Time-stop: принудительный выход через N минут
TIME_STOP_MIN=45

# Trailing stop: активируется после +20%, SL подтягивается на +10%
TRAILING_TRIGGER=0.20
TRAILING_SL_PCT=0.10

# ── Риск-менеджмент ───────────────────────────────────────────────
# Дневной лимит убытка (доля банка) → бот останавливается на сегодня
DAILY_LOSS_LIMIT_PCT=0.05

# ── Фильтры anti-rugpull ─────────────────────────────────────────
MIN_LIQUIDITY_SOL=10.0
MAX_TOP10_HOLDER_PCT=0.50
MIN_BUY_PRESSURE=0.70
MIN_UNIQUE_WALLETS=5
VOL_SURGE_MULTIPLIER=3.0

# ── Исполнение ────────────────────────────────────────────────────
# Slippage (basis points: 100 = 1%)
SLIPPAGE_BPS=150

# Priority fee (microlamports) — повышай при перегрузке сети
PRIORITY_FEE_MICROLAMPORTS=500000
