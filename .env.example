# ══════════════════════════════════════════════════════════════════
#  PUMPSCALP v3.0 — Pump.fun Direct Bonding Curve Sniper
#  Параметры выведены из 125,075 транзакций кошелька nya666...
#  (+770 SOL за 28 дней, февраль 2026)
# ══════════════════════════════════════════════════════════════════

# ── Режим ─────────────────────────────────────────────────────────
DRY_RUN=true
VIRTUAL_BALANCE_SOL=50.0

# ── Кошелёк (только для LIVE режима) ─────────────────────────────
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET=your_wallet_address_here

# ── Позиции ───────────────────────────────────────────────────────
# Медиана из реальных данных: 0.265 SOL на первый вход
# Медиана re-entry из данных: 0.297 SOL (чуть крупнее)
BUY_SIZE_SOL=0.25
BUY_SIZE_REENTRY_SOL=0.30
MAX_POSITIONS=15            # кошелёк держал 15+ одновременно (1229 токенов/день)

# ── Check-points (ВЫВЕДЕНО ИЗ ГИСТОГРАММЫ ВЫХОДОВ) ───────────────
# Пик 1 на гистограмме: 866 выходов на 5-10s → Quick Stop
QUICK_STOP_SEC=8            # T+8s: если нет роста → выходим
QUICK_STOP_MIN_PCT=0.0      # 0% = хватает любого роста чтобы остаться

# Пик 2 на гистограмме: 539 выходов на 25-30s → Momentum Gate
MOMENTUM_GATE_SEC=30        # T+30s: главный фильтр
MOMENTUM_MIN_PCT=0.03       # нужен рост +3% к T+30s
                            # (данные: 60-300s WR=54% avg=+0.16 SOL!)

# ── Выходы после momentum ─────────────────────────────────────────
TP1_PCT=0.20                # +20% → продать 50%
TP1_SELL_FRAC=0.50
TP2_PCT=0.60                # +60% → продать 50% остатка
TP2_SELL_FRAC=0.50
TP3_PCT=2.00                # +200% → продать 75% (fat tail)
TP3_SELL_FRAC=0.75

TRAILING_TRIGGER_PCT=0.15   # активировать trailing при +15%
TRAILING_DISTANCE=0.08      # -8% от пика (данные: SL кошелька ~8%)
SL_IMMEDIATE_PCT=0.05       # -5% до T+30s → немедленный стоп

# ── Жёсткий Time-Stop ─────────────────────────────────────────────
# Из данных: WR резко падает после 15 мин (300-9999s WR=50%, avg=+1.15 SOL)
HARD_TIME_STOP_MIN=15

# ── Re-entry (данные: медиана re-entry 116s после выхода) ─────────
REENTRY_MIN_SEC=60          # минимум 60s пауза
REENTRY_MAX_SEC=300         # не заходить если прошло >5 мин
REENTRY_MIN_PUMP_PCT=0.02   # токен должен вырасти ещё на 2%+ после выхода
MAX_REENTRIES=3             # максимум 3 re-entry на один токен

# ── Token Age ─────────────────────────────────────────────────────
MAX_TOKEN_AGE_SEC=120       # только токены младше 2 мин

# ── Риск ──────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_SOL=5.0    # стоп при -5 SOL в день

# ── Исполнение ────────────────────────────────────────────────────
PRIORITY_FEE_MICROLAMPORTS=500000  # высокий приоритет для первого места
SLIPPAGE_BPS=1000                  # 10% слиппаж (pump.fun быстро двигается)
