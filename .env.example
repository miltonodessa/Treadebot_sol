# ══════════════════════════════════════════════════════════════════
#  PUMPSCALP v2.0 — конфигурация
#  Выведена из анализа кошелька nya666pQkP3PzWxi7JngU3rRMHuc7zbLK8c8wxQ4qpT
#  (125,075 транзакций, +770.87 SOL за 28 дней февраля 2026)
# ══════════════════════════════════════════════════════════════════

# ── Режим работы ──────────────────────────────────────────────────
DRY_RUN=true
VIRTUAL_BALANCE_SOL=50.0

# ── Обязательные API ──────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here        # helius.xyz (free)
BIRDEYE_API_KEY=your_birdeye_api_key_here      # birdeye.so (free tier)

# ── Кошелёк (только DRY_RUN=false) ───────────────────────────────
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# ── Copy-trading ──────────────────────────────────────────────────
# Кошелёк-мастер для мониторинга (+770 SOL за 28 дней)
WATCH_WALLET=nya666pQkP3PzWxi7JngU3rRMHuc7zbLK8c8wxQ4qpT
COPY_TRADE_BONUS=30       # бонус к score если мастер купил

# ── Score / вход ──────────────────────────────────────────────────
# Снижен до 60 (v1.0 = 70): скорость важнее идеального сигнала
SCORE_THRESHOLD=60
MAX_TOKEN_AGE_MIN=20      # входим только в токены < 20 мин
SCAN_INTERVAL_SEC=15      # сканировать каждые 15с

# ── Размер позиции (ключевой параметр из данных) ──────────────────
# Из анализа: 0.5-1.0 SOL = WR 41.7%, оптимальная зона
# <0.1 SOL = WR 27.3% (убыточно!), >2 SOL = WR 62.6% (но мало капитала)
POSITION_SIZE_SOL=0.5     # базовый размер
POSITION_MAX_SOL=1.0      # максимум при высоком score или copy-trade
MAX_POSITIONS=5

# ── Momentum gate (ГЛАВНЫЙ ПАРАМЕТР) ─────────────────────────────
# Из данных: <1мин WR=30.9% УБЫТОЧНО, 1-5мин WR=53.1%, 5-15мин WR=78.2%
# Momentum gate отсекает убыточные <1мин сделки
MOMENTUM_CHECK_1_SEC=30   # проверка в T+30с
MOMENTUM_CHECK_2_SEC=60   # проверка в T+60с
MOMENTUM_MIN_1_PCT=0.02   # нужен рост +2% к T+30с
MOMENTUM_MIN_2_PCT=0.04   # нужен рост +4% к T+60с

# ── Выходы ────────────────────────────────────────────────────────
# Из данных: после 15 мин WR падает с 78.2% до 33.3%!
TIME_STOP_MIN=15          # жёсткий выход через 15 мин (не 45!)

SL_PCT=0.08               # стоп-лосс -8%
TP1_PCT=0.15              # TP1: +15% → продать 40%
TP1_FRACTION=0.40
TP2_PCT=0.50              # TP2: +50% → продать 35%
TP2_FRACTION=0.35
TP3_PCT=2.00              # TP3: +200% → продать 20%
TP3_FRACTION=0.20         # 5% держим до луны (fat right tail!)

# Trailing stop
TRAILING_TRIGGER=0.20     # активировать после +20%
TRAILING_SL_PCT=0.08      # trailing SL = -8% от пика
TAIL_TRIGGER=0.50         # при +50% ослабить trailing (может быть x10)
TAIL_SL_PCT=0.15          # fat right tail: -15% от пика

# ── Риск ──────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_PCT=0.05  # -5% банка → стоп на день

# ── Время торговли ────────────────────────────────────────────────
# Из данных по часам UTC: 18-23 и 0-3 = лучшие, 16 = убыточный
BEST_HOURS_UTC=18,19,20,21,22,23,0,1,2,3
WORST_HOURS_UTC=16
SKIP_WORST_HOURS=true     # пропускать убыточный час

# ── Anti-rugpull ──────────────────────────────────────────────────
MIN_LIQUIDITY_SOL=5.0     # снижен для более раннего входа
MAX_TOP10_HOLDER_PCT=0.60
MIN_BUY_PRESSURE=0.60
MIN_UNIQUE_WALLETS=3
VOL_SURGE_MULT=2.0

# ── Исполнение ────────────────────────────────────────────────────
SLIPPAGE_BPS=200                      # 2% слиппаж — скорость важнее
PRIORITY_FEE_MICROLAMPORTS=1000000    # высокий приоритет для быстрого входа
