# ══════════════════════════════════════════════════════════════════
#  Momentum Scalping Bot — все параметры
#  Скопируй в .env и заполни
# ══════════════════════════════════════════════════════════════════

# ── Режим работы ──────────────────────────────────────────────────
# true  = dry run (симуляция, реальных сделок НЕТ) ← начни с этого
# false = боевой режим (реальные деньги)
DRY_RUN=true

# true  = торговать только 15-23 UTC (как 2TE2F)
# false = круглосуточно (для тестирования)
TIME_FILTER=false

# ── Обязательно ───────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here

# Нужно только для боевого режима (DRY_RUN=false)
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# ── Параметры входа ───────────────────────────────────────────────
# Размер одной позиции в SOL
# 2TE2F использует 2-5 SOL; для теста начни с 0.1-0.5
BUY_SIZE_SOL=0.3

# Максимум одновременных открытых позиций
MAX_POSITIONS=3

# Дневной лимит убытка (бот уходит на паузу при достижении)
DAILY_LOSS_LIMIT_SOL=1.0

# ── Сигнал входа ──────────────────────────────────────────────────
# Окно в секундах для подсчёта покупок
SIG_WINDOW_SECS=20

# Минимум крупных покупок для сигнала-кластера
SIG_MIN_BUYS=3

# Минимальный размер одной покупки в кластере (SOL)
SIG_MIN_SOL_EACH=0.5

# Порог одной большой покупки (SOL) — сразу триггер
SIG_BIG_BUY_SOL=5.0

# Cooldown: не входить в один токен дважды за N секунд
SIG_COOLDOWN_SECS=60

# ── Уровни выхода (чанки) ─────────────────────────────────────────
# Формат: "процент_прибыли:доля_позиции" через запятую
#
# Паттерн 2TE2F (по умолчанию):
#   +15% → продаём 40%, +35% → продаём 35%, +80% → продаём остаток
EXIT_LEVELS=0.15:0.40,0.35:0.35,0.80:1.00
#
# Агрессивный (быстрый выход):
# EXIT_LEVELS=0.08:0.50,0.20:0.50
#
# Консервативный (держим дольше):
# EXIT_LEVELS=0.20:0.33,0.50:0.33,1.20:1.00

# ── Параметры выхода ──────────────────────────────────────────────
# Стоп-лосс (доля убытка от цены входа)
STOP_LOSS_PCT=0.25

# Time-stop для последнего чанка (секунды)
# Если +80% не пришло за это время — продаём по рынку
TIME_STOP_SECS=90

# Принудительный выход если позиция открыта дольше N секунд
EMERGENCY_SECS=300

# ── Исполнение ────────────────────────────────────────────────────
# Slippage (basis points: 100 = 1%)
SLIPPAGE_BPS=100

# Priority fee (microlamports) — повышай при высокой нагрузке сети
PRIORITY_FEE_MICROLAMPORTS=500000

# ── Фильтры ───────────────────────────────────────────────────────
# Blacklist: mint адреса через запятую
TOKEN_BLACKLIST=

# ── (не менять) ───────────────────────────────────────────────────
PROFIT_PARK_SOL=5.0
MAX_OPEN_POSITIONS=3
MAX_SOL_PER_TRADE=0.5
MIN_SOL_PER_TRADE=0.05
MAX_PORTFOLIO_PCT=0.10
MAX_HOLD_SECS=300
