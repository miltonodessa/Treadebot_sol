# Helius API key (get free key at https://helius.dev)
HELIUS_API_KEY=your_helius_api_key_here

# Your trading wallet
OUR_PRIVATE_KEY=your_base58_private_key_here
OUR_WALLET_ADDRESS=your_wallet_address_here

# Trading parameters
COPY_SCALE_FACTOR=0.1       # 10% of target wallet trade size
MAX_SOL_PER_TRADE=0.5       # max 0.5 SOL per trade
MIN_SOL_PER_TRADE=0.05      # skip trades < 0.05 SOL
MAX_PORTFOLIO_PCT=0.05      # max 5% of balance per trade
SLIPPAGE_BPS=100            # 1% slippage
PRIORITY_FEE_MICROLAMPORTS=100000

# Risk management
MAX_LOSS_PER_TOKEN_SOL=0.3
DAILY_LOSS_LIMIT_SOL=2.0
STOP_LOSS_PCT=0.30
TAKE_PROFIT_PCT=1.00

# Token blacklist (comma-separated mint addresses)
TOKEN_BLACKLIST=
